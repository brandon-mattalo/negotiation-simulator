# Database
DATABASE_URL=postgresql://user:password@host:5432/database_name

# JWT Secret - generate a secure random string
JWT_SECRET=your-super-secret-jwt-key-here

# Claude API Key - get from https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-...

# Environment
NODE_ENV=production
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend-url.vercel.app

# ElevenLabs voice mode - get key at https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Encryption key for recoverable student passwords (32 bytes hex)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Reviewer one-click login (/reviewer page). Passwords stay server-side and are
# never sent to the browser. Usernames are optional and default to the seeded
# reviewer-prof / reviewer-student accounts.
REVIEWER_PROF_PASSWORD=
REVIEWER_STUDENT_PASSWORD=
# REVIEWER_PROF_USERNAME=reviewer-prof
# REVIEWER_STUDENT_USERNAME=reviewer-student
